    {
      "id": "infra-text",
      "type": "text",
      "x": 70,
      "y": 250,
      "width": 760,
      "height": 60,
      "text": "Resource Group -> VNet + Subnet + NSG -> 3x Public IPs -> 3x NICs -> 3x VMs\n(All created in parallel where possible, ~5 min)\nVMs: Oracle Linux 8, Standard_D4s_v3, static private IPs (10.0.1.10/11/12)",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
